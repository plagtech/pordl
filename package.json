{
  "name": "pordl",
  "version": "0.1.0",
  "private": true,
  "description": "pordl — the open-knowledge read gateway. Fetch permitted open-content sources as clean LLM-ready markdown, metered per call over x402.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coinbase/x402": "latest",
    "@mozilla/readability": "^0.5.0",
    "@supabase/supabase-js": "^2.108.2",
    "@x402/core": "latest",
    "@x402/evm": "latest",
    "@x402/express": "latest",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsdom": "^24.1.0",
    "nanoid": "^5.1.11",
    "stripe": "^22.2.1",
    "turndown": "^7.2.0",
    "undici": "^6.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/diff": "^7.0.2",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.0",
    "@types/turndown": "^5.0.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
