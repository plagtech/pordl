# --- server ---
PORT=3000

# --- x402 billing (your pordl wallet — NOT shared with anything else) ---
PAY_TO_ADDRESS=0xYOUR_PORDL_WALLET_ADDRESS
PRICE=$0.005

# Base mainnet. For local testing use eip155:84532 (Base Sepolia) + the testnet facilitator below.
X402_NETWORK=eip155:8453

# Mainnet: Coinbase CDP facilitator (fee-free USDC settlement on Base).
# Local/testnet: https://x402.org/facilitator
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# CDP mainnet facilitator credentials (from Coinbase Developer Platform).
# Use the SAME working config you already use for Spraay — that's your known-good path.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
